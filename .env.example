# Local API
ACADEMIC_ASSISTANT_HOST=127.0.0.1
ACADEMIC_ASSISTANT_PORT=8765
ACADEMIC_ASSISTANT_DATA_DIR=./data

# Local models
ACADEMIC_ASSISTANT_EMBEDDING_MODEL=BAAI/bge-m3
ACADEMIC_ASSISTANT_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ACADEMIC_ASSISTANT_CLASSIFIER_MODEL=llama3.1:8b
ACADEMIC_ASSISTANT_GENERATOR_MODEL=llama3.1:8b
ACADEMIC_ASSISTANT_FORMATTER_MODEL=llama3.1:8b
ACADEMIC_ASSISTANT_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Ingestion
ACADEMIC_ASSISTANT_OCR_ENABLED=true
ACADEMIC_ASSISTANT_CHUNK_SIZE=1100
ACADEMIC_ASSISTANT_CHUNK_OVERLAP=200
